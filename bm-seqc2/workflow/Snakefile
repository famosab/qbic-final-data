    snakefile: 
        github("snakemake-workflows/dna-seq-benchmark", path="workflow/Snakefile", commit="e48472ef48069096e93ff6fdc1173ad62df17215")
    config:
        config


# use all rules from https://github.com/snakemake-workflows/dna-seq-benchmark
use rule * from dna_seq_benchmark
