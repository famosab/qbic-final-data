from snakemake.utils import min_version


min_version("6.10.0")


configfile: "config/config.yaml"


# declare https://github.com/snakemake-workflows/dna-seq-benchmark as a module
module dna_seq_benchmark:
    snakefile: 
        github("snakemake-workflows/dna-seq-benchmark", path="workflow/Snakefile", commit="ca9f3a1c1c8a9ca7df7161d751e52ef08180c28b")
    config:
        config


# use all rules from https://github.com/snakemake-workflows/dna-seq-benchmark
use rule * from dna_seq_benchmark
